# SentinelLM — Environment Variables
# Copy this file to .env and customize as needed

# --- LLM Backend ---
SENTINELLM_LLM_BACKEND=ollama
SENTINELLM_OLLAMA_BASE_URL=http://host.docker.internal:11434
# SENTINELLM_OPENAI_API_KEY=sk-your-key-here
# SENTINELLM_OPENAI_BASE_URL=https://api.openai.com
SENTINELLM_LLM_TIMEOUT=120.0

# --- Database ---
SENTINELLM_DATABASE_URL=postgresql+asyncpg://ppg:ppg@db:5432/ppg
SENTINELLM_DATABASE_URL_SYNC=postgresql://ppg:ppg@db:5432/ppg

# --- Semantic Model ---
SENTINELLM_MODEL_PATH=./model/trained
SENTINELLM_SEMANTIC_MODEL_ENABLED=true

# --- Policy ---
SENTINELLM_POLICY_PATH=./policies/default.yaml

# --- Server ---
SENTINELLM_HOST=0.0.0.0
SENTINELLM_PORT=8000
SENTINELLM_DEBUG=false

# --- Admin Dashboard ---
DATABASE_URL=postgresql://ppg:ppg@db:5432/ppg
